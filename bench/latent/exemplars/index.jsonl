{"id": "marshmallow-1359-datetime-bind", "repo": "marshmallow-code/marshmallow", "file": "src/marshmallow/fields.py", "qname": "DateTime::_bind_to_schema", "signature": "def _bind_to_schema(self, field_name, schema):", "body": "        super()._bind_to_schema(field_name, schema)\n        self.format = (\n            self.format\n            or getattr(self.root.opts, self.SCHEMA_OPTS_VAR_NAME)\n            or self.DEFAULT_FORMAT\n        )", "bug_summary": "self.opts is stale before _bind_to_schema; use self.root.opts", "instance_id": "marshmallow-code__marshmallow-1359", "cycle": "baseline", "keywords": ["bind", "schema", "opts", "root", "stale", "default"]}
